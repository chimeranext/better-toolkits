{
  "description": "make-no-mistakes — manifest-driven PreToolUse + PostToolUse hooks. Generic regex rules live in hooks/rules/rules.yaml (compiled to rules.json). Per-repo atomic-design enforcement lives in hooks/atomic/ and reads .atomic-design-rules.json at the consumer repo root (no-op if absent). See hooks/rules/README.md and hooks/atomic/README.md.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/atomic/pre-atomic.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__claude_ai_Slack__slack_send_message|mcp__claude_ai_Slack__slack_send_message_draft",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-slack.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/atomic/post-atomic-drift.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
